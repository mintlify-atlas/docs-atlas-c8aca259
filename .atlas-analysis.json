{
  "projectType": "sdk-library",
  "projectName": "TSGAM Estimator",
  "projectDescription": "A scikit-learn compatible Python library for time series load forecasting using Generalized Additive Models (GAMs) with Fourier seasonality, spline exogenous variables, trend, outlier detection, and autoregressive residual modeling.",
